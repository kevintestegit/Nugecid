# Docker / Compose defaults
APP_PORT=3000
HOST_BACKEND_PORT=8080
HOST_FRONTEND_PORT=3001
HOST_DB_PORT=5432
HOST_ADMINER_PORT=8081
HOST_REDIS_PORT=6379
HOST_MINIO_API_PORT=9000
HOST_MINIO_CONSOLE_PORT=9001
HOST_MEILI_PORT=7700
HOST_METABASE_PORT=3002

POSTGRES_USER=sgc
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sgc

# Aplicação
NODE_ENV=development
NODE_OPTIONS=--max-old-space-size=768 --heapsnapshot-signal=SIGUSR2
UV_THREADPOOL_SIZE=8
PORT=3000
HOST=0.0.0.0
APP_NAME="SGA-PCI"
APP_VERSION="1.0.0"
APP_DESCRIPTION="Sistema de Gestão de Arquivos - PCI/RN"
BASE_URL=http://localhost:3000
FRONTEND_URL=http://localhost:3001
APP_BASE_URL=http://localhost:3000/
PUBLIC_URL=http://localhost:3000/

# Banco de Dados (aplicação)
DATABASE_TYPE=postgres
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=sgc
DATABASE_PASSWORD=change-me
DATABASE_NAME=sgc
DATABASE_SSL=false
DATABASE_SSL_CA=
# Apenas exceção controlada para bancos sem CA configurável. Em produção prefira DATABASE_SSL_CA.
DATABASE_SSL_ALLOW_UNAUTHORIZED=false

# Docker - PostgreSQL Container
DOCKER_DB_HOST=db
DOCKER_DB_PORT=5432
DOCKER_DB_USERNAME=sgc
DOCKER_DB_PASSWORD=change-me
DOCKER_DB_NAME=sgc
DOCKER_DB_ROOT_PASSWORD=change-me

# Docker - pgAdmin
PGADMIN_EMAIL=
PGADMIN_PASSWORD=change-me
PGADMIN_PORT=8080

# Docker - Redis
DOCKER_REDIS_HOST=localhost
DOCKER_REDIS_PORT=6379
DOCKER_REDIS_PASSWORD=

# Autenticação
JWT_SECRET=replace-with-strong-secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=replace-with-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Sessão
SESSION_SECRET=replace-with-session-secret
SESSION_MAX_AGE=86400000
SESSION_SECURE=auto
# Override usado pelo docker-compose. Use true em produção pública com HTTPS.
SESSION_SECURE_OVERRIDE=auto
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
# Apenas desenvolvimento/teste. Em produção deve ser false.
ALLOW_MEMORY_SESSION_STORE=true

# Segurança
BCRYPT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900000

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=1000
RATE_LIMIT_ENABLED=true
# Defina o número exato de hops confiáveis. O proxy público deve sobrescrever
# X-Forwarded-For, X-Forwarded-Proto e X-Forwarded-Host.
TRUST_PROXY_HOPS=1
RATE_LIMIT_GLOBAL_WINDOW_MS=900000
RATE_LIMIT_GLOBAL_MAX=1000
RATE_LIMIT_UPLOAD_WINDOW_MS=300000
RATE_LIMIT_UPLOAD_MAX=500
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_LOGIN_MAX=20
RATE_LIMIT_REGISTER_WINDOW_MS=900000
RATE_LIMIT_REGISTER_MAX=10

# Cache (Redis - opcional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TTL=3600
REDIS_URL=redis://localhost:6379/0

# Fila de Mensagens
RABBITMQ_URL=amqp://localhost:5672
RABBITMQ_QUEUE_NAME=sgc-itep-queue

# Upload de Arquivos
UPLOAD_PATH=./uploads
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=pdf,doc,docx,xls,xlsx,jpg,jpeg,png,gif
STORAGE_DRIVER=local
STORAGE_S3_ENDPOINT=http://localhost:9000
STORAGE_S3_REGION=us-east-1
STORAGE_S3_BUCKET=sgc-documentos
STORAGE_S3_ACCESS_KEY=minioadmin
STORAGE_S3_SECRET_KEY=change-me-minio
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_S3_AUTO_CREATE_BUCKET=true
CLAMAV_ENABLED=false
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
CLAMAV_TIMEOUT_MS=10000
# true = libera upload quando o ClamAV estiver indisponível; false = bloqueia
CLAMAV_FAIL_OPEN=false
OCR_ENABLED=false
OCR_COMMAND=ocrmypdf
OCR_LANGUAGE=por
OCR_TIMEOUT_MS=180000
OCR_TESSERACT_TIMEOUT=180
# true = não bloqueia upload se o OCR falhar; false = falha o upload em caso de erro operacional
# Em produção deve ser false.
OCR_FAIL_OPEN=false
SEARCH_ENABLED=false
SEARCH_MEILI_HOST=http://localhost:7700
SEARCH_MEILI_API_KEY=change-me-search
SEARCH_MEILI_INDEX=global_documents
# true = ignora indisponibilidade do índice e mantém fallback SQL; false = trata a falha como erro
# Em produção deve ser false.
SEARCH_FAIL_OPEN=false
# true = reindexa desarquivamentos/pastas/planilhas na inicialização
SEARCH_BOOTSTRAP_ON_START=false
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_SUBJECT=mailto:admin@example.com

# MinIO (profile opcional "storage" no docker-compose)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-minio
MEILI_MASTER_KEY=change-me-search
METABASE_IMAGE=metabase/metabase:v0.59.1.x
METABASE_SITE_URL=http://localhost:3002
METABASE_APP_DB=metabase_app
METABASE_APP_USER=metabase_app
METABASE_APP_PASSWORD=change-me-metabase-app
METABASE_ANALYTICS_DB=sgc
METABASE_ANALYTICS_SCHEMA=analytics
METABASE_ANALYTICS_USER=metabase_analytics
METABASE_ANALYTICS_PASSWORD=change-me-metabase-analytics

# CORS
CORS_ORIGIN=http://localhost:3001
CORS_CREDENTIALS=true
CORS_METHODS=GET,HEAD,PUT,PATCH,POST,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Accept,Authorization,X-Requested-With

# Logging
LOG_LEVEL=debug
LOG_FILE=./logs/app.log
LOG_FORMAT=combined
LOG_MAX_FILES=30
LOG_MAX_SIZE=10m

# Email
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-password
EMAIL_FROM="SGA-PCI <no-reply@example.com>"

# Feature Flags
FEATURE_QUEUE_ENABLED=false
ENABLE_AUDIT_LOG=true
ENABLE_FILE_UPLOAD=true
ENABLE_NOTIFICATIONS=false
ENABLE_EXCEL_IMPORT=true
ENABLE_BARCODE_GENERATION=true

# Runtime resources (docker-compose backend)
BACKEND_MEM_LIMIT=1024m
BACKEND_CPUS=1.50
BACKEND_PIDS_LIMIT=256

# Paginação
DEFAULT_PAGE_SIZE=10
MAX_PAGE_SIZE=100

# Timezone
TZ=America/Fortaleza

# Backup
BACKUP_ENABLED=true
BACKUP_MAX_DAYS=30
BACKUP_MAX_FILES=120
BACKUP_MAX_SIZE_GB=20
BACKUP_DIR=./backups
BACKUP_HTTP_RESTORE_ENABLED=false
DOCKER_CONTAINER=false
# Escavador externo (webhook)
# Segredo compartilhado entre o watcher Python (host) e o backend para assinatura HMAC.
# ESCAVADOR_WEBHOOK_TOKEN=um-token-secreto
# Janela máxima de replay aceita pelo backend, em segundos.
# ESCAVADOR_WEBHOOK_TOLERANCE_SECONDS=300
# Fallback temporário para Bearer token legado. Mantenha false após migrar o watcher.
# ESCAVADOR_WEBHOOK_ALLOW_LEGACY_TOKEN=false
# Usuário que receberá notificações quando o watcher externo detectar novo processo.
# ESCAVADOR_NOTIFY_USER_ID=1
# Endpoint inicial e credenciais do portal externo.
# LAUNCH_URL=https://seirn.itep.rn.gov.br
# SEI_USUARIO=seu_usuario
# SEI_SENHA=sua_senha
# ESCAVADOR_PYTHON_BIN=python3

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=

# Sentry Frontend (Vite)
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development
VITE_SENTRY_RELEASE=
VITE_SENTRY_TRACES_SAMPLE_RATE=0.1
VITE_SENTRY_REPLAY_SESSION_SAMPLE_RATE=0
VITE_SENTRY_REPLAY_ON_ERROR_SAMPLE_RATE=1
