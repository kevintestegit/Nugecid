{
  "name": "sgc-itep-nestjs",
  "version": "1.0.0",
  "description": "Sistema Integrado de Gestão Documental - ITEP-RN",
  "author": "Kevin Patrick Borges",
  "private": true,
  "license": "UNLICENSED",
  "engines": {
    "node": "^24.0.0"
  },
  "overrides": {
    "lodash": "^4.18.1",
    "path-to-regexp": "^8.4.2"
  },
  "_moduleAliases": {
    "@": "dist/src"
  },
  "scripts": {
    "build": "npm run build:backend && npm run build:frontend",
    "build:backend": "nest build",
    "build:frontend": "cd frontend && npm run build",
    "format": "npm run format:backend && npm run frontend:format",
    "format:backend": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "format:check": "npm run format:check:backend && npm run frontend:format:check",
    "format:check:backend": "prettier --check \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "dev": "node scripts/check-docker.js && concurrently \"npm:start:backend\" \"npm:start:frontend\"",
    "dev:safe": "concurrently \"npm:start:backend\" \"npm:start:frontend\"",
    "start:backend": "nest start --watch",
    "start:frontend": "cd frontend && npm run dev",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/src/main.js",
    "lint": "npm run lint:backend && npm run frontend:lint",
    "lint:backend": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "npm run lint:fix:backend && npm run frontend:lint:fix",
    "lint:fix:backend": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "typecheck": "npm run typecheck:backend && npm run frontend:typecheck",
    "typecheck:backend": "tsc --noEmit",
    "test": "jest",
    "test:unit": "npm run test -- --passWithNoTests",
    "test:critical": "npm run test -- --runInBand src/modules/auth/auth.controller.spec.ts src/modules/auth/guards/web-auth.guard.spec.ts src/modules/health/health.controller.spec.ts src/app.controller.spec.ts src/modules/planilhas/planilhas.controller.spec.ts src/modules/search/search.service.spec.ts src/common/utils/file-validator.spec.ts src/modules/nugecid/domain/entities/desarquivamento.entity.spec.ts src/modules/nugecid/application/services/desarquivamento-effects.publisher.spec.ts src/modules/nugecid/infrastructure/repositories/desarquivamento.typeorm-repository.spec.ts src/modules/nugecid/nugecid-anexos.service.spec.ts",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "playwright test",
    "test:e2e:api": "jest --config ./test/jest-e2e.config.js",
    "test:e2e:ui": "playwright test",
    "test:e2e:ui:headed": "playwright test --headed",
    "test:e2e:ui:debug": "playwright test --debug",
    "test:e2e:install": "npx playwright install chromium",
    "e2e:start:backend": "bash scripts/start-backend-e2e.sh",
    "e2e:start:frontend": "bash scripts/start-frontend-e2e.sh",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "typeorm-ts-node-commonjs migration:generate -d src/config/migration.config.ts",
    "migration:run": "typeorm-ts-node-commonjs migration:run -d src/config/migration.config.ts",
    "migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/config/migration.config.ts",
    "migration:run:dist": "typeorm migration:run -d dist/src/config/migration.config.js",
    "migration:revert:dist": "typeorm migration:revert -d dist/src/config/migration.config.js",
    "migration:show:dist": "typeorm migration:show -d dist/src/config/migration.config.js",
    "webpush:generate-keys": "node scripts/generate-web-push-vapid-keys.js",
    "webpush:setup-env": "node scripts/generate-web-push-vapid-keys.js --write-env",
    "seed": "ts-node src/database/seeds/run-seeds.ts",
    "check:roles": "ts-node scripts/check-roles.ts",
    "check:docker": "node scripts/check-docker.js",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:backup": "bash scripts/backup-cli.sh full",
    "docker:restore": "bash scripts/restore-dump.sh",
    "backup:full": "bash scripts/backup-cli.sh full",
    "backup:desarq": "bash scripts/backup-cli.sh desarq",
    "backup:list": "bash scripts/backup-cli.sh list",
    "backup:clean": "bash scripts/backup-cli.sh clean",
    "backup:size": "bash scripts/backup-cli.sh size",
    "backup:verify": "bash scripts/backup-verify.sh",
    "backup:offsite": "bash scripts/backup-offsite-sync.sh",
    "system:check": "bash scripts/check-system.sh",
    "smoke:test": "bash scripts/smoke-test.sh",
    "debug:collect": "bash scripts/collect-debug-info.sh",
    "frontend:lint": "cd frontend && npm run lint",
    "frontend:lint:fix": "cd frontend && npm run lint:fix",
    "frontend:format": "cd frontend && npm run format",
    "frontend:format:check": "cd frontend && npm run format:check",
    "frontend:typecheck": "cd frontend && npm run typecheck",
    "frontend:test": "cd frontend && npm run test -- --run",
    "frontend:test:critical": "cd frontend && npm run test -- --run src/__tests__/AuthContext.test.tsx src/__tests__/ProtectedRoute.test.tsx src/__tests__/DesarquivamentosPage.test.tsx src/pages/__tests__/TermoDesarquivamentoPreviewPage.test.tsx",
    "frontend:test:unit": "cd frontend && npm run test -- --run",
    "frontend:build": "cd frontend && npm run build",
    "frontend:bundle:check": "cd frontend && npm run check:bundle-size",
    "quality:critical": "npm run lint && npm run typecheck && npm run test:critical && npm run frontend:test:critical",
    "quality:check": "npm run format:check && npm run lint && npm run typecheck && npm run test:unit && npm run frontend:test:unit",
    "quality:ci": "npm run quality:check && npm run build && npm run frontend:bundle:check"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1038.0",
    "@nestjs-modules/mailer": "^2.3.7",
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/cache-manager": "^3.1.3",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/event-emitter": "^3.1.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/serve-static": "^5.0.5",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/typeorm": "^11.0.1",
    "@sentry/nestjs": "^10.41.0",
    "@sentry/node": "^10.41.0",
    "@types/jsdom": "^21.1.7",
    "@types/pg": "^8.15.5",
    "@types/web-push": "^3.6.4",
    "@xmldom/xmldom": "^0.9.10",
    "axios": "^1.15.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.76.2",
    "cache-manager-redis-store": "^3.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "compression": "^1.7.4",
    "connect-redis": "^7.1.1",
    "cookie-parser": "^1.4.7",
    "csv-parse": "^5.6.0",
    "date-fns": "^4.1.0",
    "docx": "^9.5.1",
    "exceljs": "^4.4.0",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "fast-xml-parser": "^5.7.2",
    "file-type": "^21.1.0",
    "follow-redirects": "^1.16.0",
    "helmet": "^7.1.0",
    "html-to-docx": "^1.8.0",
    "html-to-pdfmake": "^2.5.32",
    "ioredis": "^5.9.3",
    "jsdom": "^27.0.0",
    "mammoth": "^1.11.0",
    "meilisearch": "^0.56.0",
    "module-alias": "^2.2.3",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "passport": "^0.7.0",
    "passport-custom": "^1.1.1",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.17.2",
    "pdfmake": "^0.2.20",
    "pg": "^8.16.3",
    "playwright": "^1.56.1",
    "postcss": "^8.5.12",
    "prom-client": "^15.1.3",
    "redis": "^4.6.10",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "typeorm": "^0.3.28",
    "web-push": "^3.6.7",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@playwright/test": "^1.54.2",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^4.17.17",
    "@types/express-session": "^1.17.10",
    "@types/jest": "^29.5.2",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.3.1",
    "@types/nodemailer": "^8.0.1",
    "@types/passport-jwt": "^3.0.13",
    "@types/passport-local": "^1.0.38",
    "@types/supertest": "^2.0.12",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "concurrently": "^9.2.0",
    "dataloader": "^2.2.3",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "jest": "^29.5.0",
    "prettier": "^3.0.0",
    "sharp": "^0.34.5",
    "source-map-support": "^0.5.21",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.0",
    "ts-loader": "^9.4.3",
    "ts-node": "^10.9.1",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.1.3"
  }
}
